---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout language="es" title="Próximamente — AMULET" description="Amulet se está preparando para iPhone." canonicalPath="/proximamente/" robots="noindex, follow">
<main class="soon-wrap"><div><p class="eyebrow">AMULET</p><h1>Próximamente<br /><span>Coming soon</span></h1><p>La app se está preparando para iPhone. · The app is being prepared for iPhone.</p><div class="soon-line" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div><a href="/">amulet.cards</a></div></main>
</BaseLayout>
<style>
.soon-wrap{min-height:100svh;display:grid;place-items:center;text-align:center;padding:24px}.soon-wrap h1{font-family:"Cormorant",serif;font-weight:300;font-size:clamp(48px,10vw,88px);line-height:1;margin:0}.soon-wrap h1 span{color:var(--dim)}.soon-wrap p{color:var(--dim);margin:18px 0 0}.soon-wrap a{margin-top:28px;display:inline-block;text-decoration:none;border-bottom:1px solid var(--faint)}.eyebrow{text-transform:uppercase;letter-spacing:.08em;font-size:12px}.soon-line{width:min(340px,60vw);height:1px;margin:38px auto 0;display:grid;grid-template-columns:repeat(5,1fr)}.soon-line i:nth-child(1){background:var(--vermilion)}.soon-line i:nth-child(2){background:var(--lemon)}.soon-line i:nth-child(3){background:var(--cobalt)}.soon-line i:nth-child(4){background:var(--rose)}.soon-line i:nth-child(5){background:var(--leaf)}
</style>
