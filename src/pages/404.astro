---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout language="en" title="Page not found — AMULET" description="This page could not be found." canonicalPath="/404/" robots="noindex, follow">
<main class="not-found"><div><p>AMULET</p><h1>404</h1><p>Page not found · Página no encontrada</p><a href="/">Return home · Volver al inicio</a></div></main>
</BaseLayout>
<style>.not-found{min-height:100svh;display:grid;place-items:center;text-align:center;padding:24px}.not-found h1{margin:0;font-family:"Cormorant",serif;font-size:clamp(80px,20vw,180px);font-weight:300;color:var(--cobalt)}.not-found p{color:var(--dim)}.not-found a{display:inline-block;margin-top:24px}</style>
