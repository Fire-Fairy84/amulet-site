---
import type { Language } from '../lib/i18n';
interface Item { label: string; href?: string }
interface Props { language: Language; items: Item[] }
const { items } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {items.map((item, index) => <li>{item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}{index < items.length - 1 && <span aria-hidden="true">·</span>}</li>)}
  </ol>
</nav>
