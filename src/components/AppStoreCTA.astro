---
import { labels, type Language } from '../lib/i18n';
interface Props { language: Language }
const { language } = Astro.props;
const t = labels[language];
---
<aside class="card-cta" aria-labelledby="app-cta-title">
  <h2 id="app-cta-title">{t.journal}</h2>
  <p>{t.cta}</p>
  <a class="store-badge muted" href="/proximamente/" aria-label={t.comingSoon}>
    <img src="/assets/app-store-badge.svg" alt={t.appStore} width="120" height="40" loading="lazy" />
  </a>
  <small>{t.comingSoon}</small>
</aside>
