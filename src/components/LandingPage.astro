---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cardIndexPath, type Language } from '../lib/i18n';
import '../styles/landing.css';

interface Props { language: Language; canonicalPath: '/' | '/en/' | '/es/' }
const { language, canonicalPath } = Astro.props;
const es = language === 'es';
const copy = es ? {
  title: 'AMULET — Diario de tarot: saca tu carta o registra tu tirada',
  description: 'AMULET es un diario de tarot para conocerte mejor. Saca tu carta del día en la app —barajado real, cartas invertidas— o registra la tirada que hiciste con tu mazo. Significados de los 78 arcanos, patrones y privacidad. Sin suscripción.',
  deckNav: 'El mazo', patternsNav: 'Patrones', meaningsNav: 'Significados', privacyNav: 'Privacidad', soon: 'Próximamente', other: 'English', otherPath: '/en/',
  eyebrow: 'Diario de tarot para iOS', heroLine: 'El tarot no adivina tu futuro.', heroEm: 'Te devuelve tu presente.',
  intro: 'Un diario de tarot para conocerte mejor, carta a carta. Saca tu carta del día dentro de la app o registra la tirada que acabas de hacer con tu mazo: AMULET guarda lo que las cartas te dijeron y te ayuda a entenderlo.',
  appAlt: 'Descargar en el App Store', todayAlt: 'Pantalla de Hoy de Amulet con la carta del día, una racha de cuatro días y tiradas recientes',
  principles: [['Tira o registra','Saca tu carta del día en la app, o anota la tirada que hiciste con tu propio mazo.'],['Diario privado','Cada tirada queda guardada con su fecha y lo que viste en ella. Solo para ti.'],['Patrones con el tiempo','AMULET recuerda por ti y te enseña qué cartas y qué temas vuelven mes a mes.']],
  deckCaption: ['LOS 22 MAYORES / LOS 56 MENORES','SIGNIFICADOS DEL DERECHO Y DEL REVÉS'], deckKicker: '01 / El mazo', deckTitle: 'Con mazo en mano', deckTitle2: 'o sin él.',
  deckDescription: 'Saca tu carta del día dentro de la app —barajado real, cartas invertidas incluidas— o registra la tirada que acabas de hacer con tu mazo físico. No importa el camino: AMULET la guarda y te ayuda a leerla.',
  deckContext: 'Dos formas de tirar, un mismo cuaderno.', deckPoints: [['Carta del día','Barajado real dentro de la app, al derecho o invertida, con su símbolo y su lectura.'],['Tu tirada física','Registra libremente la tirada que hiciste con tu propio mazo, con su pregunta y su fecha.'],['Los 78 arcanos','Todo el mazo a mano: 22 mayores y 56 menores, para consultar y aprender.']], libraryAlt: 'Biblioteca de cartas de Amulet con los arcanos mayores en una rejilla editorial a color',
  patternsKicker: '02 / Patrones', patternsTitle: 'Lo que se repite', patternsTitle2: 'dice más que una tirada.', patternsText: 'Una carta sola es un momento. Muchas tiradas, guardadas mes a mes, son un patrón. AMULET cuenta lo que vuelve —cartas, palos, inversiones— y te enseña lo que tú solo no verías: «La Torre te ha salido 4 veces este mes».', patternsItems: ['Cartas que insisten: qué arcano aparece una y otra vez, y cuándo empezó','Palos e inversiones: si tus tiradas se cargan de un palo, o algo te sale invertido sin parar','Temas del mes: por dónde ha ido tu mes, según tus propias cartas'], patternsAlt: 'Pantalla de Patrones de Amulet con la carta recurrente del mes',
  meaningsKicker: '03 / Significados', meaningsTitle: 'Cada arcano,', meaningsTitle2: 'por dentro.', meaningsText: 'Los significados de los 78 arcanos, al derecho e invertidos, escritos para reflexionar y no para asustar. Sin jerga cerrada: texto claro que te ayuda a entender qué tienes delante y qué te está diciendo.', quote: 'La Estrella: después de la tormenta, vuelves a fiarte de algo. Todavía no sabes de qué, pero ya no estás a oscuras.', quoteCite: 'LA ESTRELLA', detailAlt: 'Detalle de una carta en Amulet, con su significado al derecho e invertido',
  privacyKicker: '04 / Privacidad', privacyTitle: 'Lo que escribes', privacyTitle2: 'se queda contigo.', privacyText: 'Tu diario es tuyo. AMULET no pide cuentas ni sube tus tiradas a ningún servidor. Lo que anotas vive en tu teléfono, y tú decides si lo respaldas.', privacyItems: [['Sin cuenta','Nada de registros ni contraseñas. Abres la app y ya está.'],['iCloud privado','Tu diario se respalda en tu propio iCloud, cifrado y a tu nombre.'],['Todo en el dispositivo','Los significados y las lecturas funcionan en tu teléfono, sin conexión.'],['Un solo pago','Tuyo para siempre. Sin suscripción, sin anuncios.']],
  closeKicker: '05 / Próximamente', closeTitle: 'Con mazo en mano', closeTitle2: 'o sin él.', closeText: 'AMULET es el lugar donde vuelves a mirar tus cartas. Disponible pronto en la App Store.', footer: 'AMULET / DIARIO DE TAROT', contact: 'Contacto', skip: 'Saltar al contenido', meaningsLink: 'Explorar los significados de las cartas',
} : {
  title: 'AMULET — Tarot journal: draw a card or log your reading',
  description: 'AMULET is a private tarot journal for iOS. Draw your daily card or log a reading with your own deck. Explore all 78 cards, upright and reversed. No subscription.',
  deckNav: 'The deck', patternsNav: 'Patterns', meaningsNav: 'Meanings', privacyNav: 'Privacy', soon: 'Coming soon', other: 'Español', otherPath: '/es/',
  eyebrow: 'A tarot journal for iOS', heroLine: "The cards don't predict your future.", heroEm: 'They hand you your present.',
  intro: 'A tarot journal for knowing yourself better, one card at a time. Draw your daily card inside the app, or log the reading you just did with your deck — AMULET keeps what the cards told you and helps you understand it.',
  appAlt: 'Download on the App Store', todayAlt: 'Amulet Today screen with the card of the day, a four-day streak, and recent readings',
  principles: [['Draw or log','Draw your daily card in the app, or record the reading you did with your own deck.'],['Private journal','Every reading is saved with its date and what you saw in it. Yours alone.'],['Patterns over time','Amulet remembers for you and shows which cards and themes keep coming back.']],
  deckCaption: ['THE 22 MAJORS / ALL 56 MINORS','UPRIGHT AND REVERSED MEANINGS'], deckKicker: '01 / The deck', deckTitle: 'Deck in hand,', deckTitle2: 'or not.',
  deckDescription: 'Draw your daily card inside the app —real shuffle, reversals included— or log the reading you just did with your physical deck. Either way, Amulet keeps it and helps you read it.',
  deckContext: 'Two ways to draw, one journal.', deckPoints: [['Daily card','A real shuffle inside the app, upright or reversed, with its symbol and reading.'],['Your physical reading','Freely log the spread you did with your own deck, with its question and date.'],['All 78 arcana','The whole deck on hand: 22 major and 56 minor, to check and learn.']], libraryAlt: 'Amulet card library showing the Major Arcana as a colorful editorial grid',
  patternsKicker: '02 / Patterns', patternsTitle: 'What repeats', patternsTitle2: 'says more than one reading.', patternsText: 'One card is a moment. Many readings, kept month after month, are a pattern. Amulet counts what returns —cards, suits, reversals— and shows what you’d miss on your own: “The Tower has come up 4 times this month.”', patternsItems: ['Cards that insist: which arcana shows up again and again, and when it started','Suits and reversals: if your readings lean into one suit, or something keeps landing reversed','The month’s theme: where your month went, by your own cards'], patternsAlt: 'Amulet Patterns screen showing the recurring card of the month',
  meaningsKicker: '03 / Meanings', meaningsTitle: 'Every arcana,', meaningsTitle2: 'from the inside.', meaningsText: 'Meanings for all 78 arcana, upright and reversed, written to make you reflect —not to scare you. No closed jargon: clear text that helps you understand what’s in front of you.', quote: 'The Star: after the storm, you trust something again. You don’t know what yet, but you’re no longer in the dark.', quoteCite: 'THE STAR', detailAlt: 'A card detail in Amulet with its upright and reversed meaning',
  privacyKicker: '04 / Privacy', privacyTitle: 'What you write', privacyTitle2: 'stays with you.', privacyText: 'Your journal is yours. Amulet asks for no account and sends your readings to no server. What you note lives on your phone, and you decide whether to back it up.', privacyItems: [['No account','No sign-ups, no passwords. Open the app and you’re in.'],['Private iCloud','Your journal backs up to your own iCloud, encrypted and in your name.'],['All on device','Meanings and readings work on your phone, offline.'],['One purchase','Yours forever. No subscription, no ads.']],
  closeKicker: '05 / Coming Soon', closeTitle: 'Deck in hand,', closeTitle2: 'or not.', closeText: 'Amulet is where you come back to look at your cards. Coming soon to the App Store.', footer: 'AMULET / TAROT JOURNAL', contact: 'Contact', skip: 'Skip to content', meaningsLink: 'Explore all tarot card meanings',
};
const landingAlternates = [{ language: 'en' as const, path: '/en/' }, { language: 'es' as const, path: '/es/' }];
if (canonicalPath === '/en/') {
  copy.title = 'AMULET in English — Tarot journal for iOS';
  copy.description = 'Explore the English version of AMULET, a private tarot journal for iOS with all 78 cards, upright and reversed meanings, and patterns over time.';
}
const websiteLd = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'AMULET', url: 'https://amulet.cards/', description: copy.description, inLanguage: language };
---
<BaseLayout language={language} title={copy.title} description={copy.description} canonicalPath={canonicalPath} alternates={landingAlternates} jsonLd={websiteLd} bodyClass="landing">
  <a class="skip-link" href="#main">{copy.skip}</a>
  <header class="site-header" aria-label={es ? 'Navegación principal' : 'Main navigation'}>
    <a class="brand" href="#top" aria-label="AMULET">AMULET</a>
    <nav class="nav"><a href="#practice">{copy.deckNav}</a><a href="#patterns">{copy.patternsNav}</a><a href={cardIndexPath(language)}>{copy.meaningsNav}</a><a href="#privacy">{copy.privacyNav}</a><a class="launch-status" href="#launch">{copy.soon}</a><a class="lang-toggle" href={copy.otherPath} hreflang={es ? 'en' : 'es'}>{copy.other}</a></nav>
  </header>
  <main id="main">
    <section class="hero" id="top" aria-labelledby="hero-title"><div class="hero-inner"><div class="hero-copy"><p class="eyebrow">{copy.eyebrow}</p><h1 id="hero-title">AMULET</h1><p class="hero-line">{copy.heroLine}<br /><em>{copy.heroEm}</em></p><p class="hero-intro">{copy.intro}</p><div class="hero-actions"><a class="store-badge hero-badge" href="/proximamente/" aria-label={copy.soon}><img src="/assets/app-store-badge.svg" alt={copy.appAlt} width="148" height="44" /></a></div></div><figure class="hero-screen"><img src="/assets/screens/01-today.webp" width="1320" height="2868" alt={copy.todayAlt} /></figure><div class="pigment-index" aria-hidden="true"><span style="background:var(--vermilion)"></span><span style="background:var(--lemon)"></span><span style="background:var(--cobalt)"></span><span style="background:var(--rose)"></span><span style="background:var(--leaf)"></span></div></div></section>
    <section class="principles"><div class="principles-inner">{copy.principles.map(([heading, text]) => <div class="principle"><strong>{heading}</strong><span>{text}</span></div>)}</div></section>
    <section class="section deck-section" id="practice" aria-labelledby="practice-title"><div class="deck-showcase reveal"><div class="deck-visual"><div class="gallery-window"><img src="/assets/screens/04-card-library.webp" width="1320" height="2868" alt={copy.libraryAlt} loading="lazy" /></div><div class="gallery-caption"><span>{copy.deckCaption[0]}</span><span>{copy.deckCaption[1]}</span></div></div><div class="deck-content"><span class="section-kicker">{copy.deckKicker}</span><h2 id="practice-title">{copy.deckTitle}<br />{copy.deckTitle2}</h2><p class="section-description">{copy.deckDescription}</p><p><a href={cardIndexPath(language)}>{copy.meaningsLink} →</a></p></div><div class="deck-context"><h3>{copy.deckContext}</h3><ul class="deck-points">{copy.deckPoints.map(([heading, text]) => <li><span>{heading}</span><strong>{text}</strong></li>)}</ul></div></div></section>
    <section class="feature-band media-right" id="patterns" aria-labelledby="patterns-title"><div class="feature-band-inner"><div class="feature-copy reveal"><span class="section-kicker">{copy.patternsKicker}</span><h2 id="patterns-title">{copy.patternsTitle}<br />{copy.patternsTitle2}</h2><p>{copy.patternsText}</p><ul class="feature-notes">{copy.patternsItems.map((text, index) => <li><i aria-hidden="true" style={index === 1 ? 'background:var(--lemon)' : index === 2 ? 'background:var(--vermilion)' : undefined}></i><span>{text}</span></li>)}</ul></div><figure class="screen-frame reveal"><img src="/assets/screens/03-patterns.webp" width="1320" height="2868" alt={copy.patternsAlt} decoding="async" /></figure></div></section>
    <section class="feature-band media-left meaning-band" aria-labelledby="meaning-title"><div class="feature-band-inner"><figure class="screen-frame reveal"><img src="/assets/screens/05-card-detail.webp" width="1320" height="2868" alt={copy.detailAlt} decoding="async" /></figure><div class="feature-copy reveal"><span class="section-kicker">{copy.meaningsKicker}</span><h2 id="meaning-title">{copy.meaningsTitle}<br />{copy.meaningsTitle2}</h2><p>{copy.meaningsText}</p><blockquote class="quote">{copy.quote}<cite>{copy.quoteCite}</cite></blockquote><p><a href={cardIndexPath(language)}>{copy.meaningsLink} →</a></p></div></div></section>
    <section class="privacy" id="privacy" aria-labelledby="privacy-title"><div class="privacy-heading reveal"><div><span class="section-kicker">{copy.privacyKicker}</span><h2 id="privacy-title">{copy.privacyTitle}<br />{copy.privacyTitle2}</h2></div><p>{copy.privacyText}</p></div><div class="privacy-grid reveal">{copy.privacyItems.map(([heading, text], index) => <article class="privacy-item" style={`color:${['var(--vermilion)','var(--lemon)','var(--cobalt)','var(--leaf)'][index]}`}><span class="mark" aria-hidden="true"></span><h3 style="color:var(--bone)">{heading}</h3><p>{text}</p></article>)}</div></section>
    <section class="closing" id="launch" aria-labelledby="launch-title"><div class="closing-inner reveal"><span class="section-kicker">{copy.closeKicker}</span><h2 id="launch-title">{copy.closeTitle}<br />{copy.closeTitle2}</h2><p>{copy.closeText}</p><a class="store-badge" href="/proximamente/" aria-label={copy.soon}><img src="/assets/app-store-badge.svg" alt={copy.appAlt} width="120" height="40" loading="lazy" /></a><div class="color-line" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></div></div></section>
  </main>
  <footer class="site-footer"><span>{copy.footer}</span><div class="footer-links"><a href="/privacy/">{copy.privacyNav}</a><a href="/terms/">Terms</a><a href="mailto:esthersarasua.dev@gmail.com">{copy.contact}</a></div></footer>
</BaseLayout>
